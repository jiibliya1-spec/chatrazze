{\n  "name": "chatraze",\n  "version": "1.0.0",\n  "description": "A modern, fast, and secure real-time messaging platform similar to WhatsApp",\n  "private": true,\n  "workspaces": ["frontend", "backend"],\n  "scripts": {\n    "install-all": "npm install && npm install --workspace frontend && npm install --workspace backend",\n    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",\n    "dev:frontend": "npm run dev --workspace frontend",\n    "dev:backend": "npm run dev --workspace backend",\n    "build": "npm run build --workspace frontend && npm run build --workspace backend",\n    "start": "node backend/dist/index.js",\n    "test": "npm run test --workspace frontend && npm run test --workspace backend"\n  },\n  "keywords": ["messaging", "chat", "real-time", "websocket"],\n  "author": "Chatraze Team",\n  "license": "MIT",\n  "devDependencies": {\n    "concurrently": "^8.2.0"\n  }\n}